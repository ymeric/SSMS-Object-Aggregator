<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Id="SSMS.ObjectAggregator.Vsix" Version="1.0.2" Language="en-US" Publisher="Yalin Meric" />
    <DisplayName>SSMS Object Aggregator</DisplayName>
    <Description xml:space="preserve">Adds the Smart Object Filter window to SSMS 22.</Description>
