<Window x:Class="SSMS.ObjectAggregator.Views.FilterDefinitionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filter Definition"
        Height="240"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Schema name filter" FontWeight="SemiBold" />
        <TextBox x:Name="SchemaTextBox"
                 Grid.Row="1"
                 Margin="0,4,0,0"
                 TextChanged="OnTextChanged" />

        <TextBlock Grid.Row="3" Text="Object name filter" FontWeight="SemiBold" />
        <TextBox x:Name="ObjectTextBox"
                 Grid.Row="4"
                 Margin="0,4,0,0"
                 TextChanged="OnTextChanged" />

        <TextBlock Grid.Row="5"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Foreground="Gray"
                   FontSize="12"
                   Text="Use * for starts/ends-with, ? for single characters, and combine patterns as needed." />

        <TextBlock x:Name="WarningText"
                   Grid.Row="6"
                   Foreground="DarkRed"
                   FontSize="12"
                   Text="Enter at least one filter."
                   Visibility="Collapsed" />

        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" IsCancel="True" />
            <Button x:Name="OkButton" Content="OK" Width="80" IsDefault="True" Click="OkButton_Click" />
        </StackPanel>
    </Grid>
</Window>