<Window x:Class="SSMS.ObjectAggregator.Views.GroupDefinitionWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SSMS.ObjectAggregator.ViewModels"
        xmlns:conv="clr-namespace:SSMS.ObjectAggregator.Converters"
        Title="Group Definition"
        Height="520"
        Width="520"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Actions" ItemsSource="{Binding ActiveActions}">
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Header" Value="{Binding Header}" />
                        <Setter Property="Command" Value="{Binding Command}" />
                    </Style>
                </MenuItem.ItemContainerStyle>
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top" IsLocked="True">
        <ToolBar>
            <ItemsControl ItemsSource="{Binding ActiveActions}" Margin="0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding Command}" Margin="2" ToolTip="{Binding Header}">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="{Binding IconGlyph}" FontSize="16" />
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ToolBar>
        </ToolBarTray>

        <TreeView x:Name="DefinitionTree"
                  ItemsSource="{Binding Instances}"
                  SelectedItemChanged="DefinitionTree_OnSelectedItemChanged"
                  PreviewKeyDown="DefinitionTree_OnPreviewKeyDown">
            <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type vm:InstanceNodeViewModel}" ItemsSource="{Binding Children}">
                    <Grid>
                        <Grid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Insert"
                                          Command="{Binding DataContext.AddInstanceCommand, Source={x:Reference RootWindow}}" />
                                <MenuItem Header="Edit"
                                          Command="{Binding DataContext.EditInstanceContextCommand, Source={x:Reference RootWindow}}"
                                           CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Delete"
                                          Command="{Binding DataContext.DeleteInstanceContextCommand, Source={x:Reference RootWindow}}"
                                           CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Filter Definitions"
                                          Command="{Binding DataContext.FilterDefinitionsContextCommand, Source={x:Reference RootWindow}}"
                                           CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            </ContextMenu>
                        </Grid.ContextMenu>
                        <StackPanel Orientation="Vertical"
                                    Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}">
                            <TextBlock Text="{Binding Model.InstanceName, TargetNullValue=(unnamed)}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Model.DatabaseName, StringFormat=Database: {0}, TargetNullValue=Database: (unspecified)}"
                                       FontStyle="Italic"
                                       Foreground="Gray" />
                        </StackPanel>
                        <StackPanel x:Name="InstanceEditorPanel"
                                    Orientation="Vertical"
                                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                                    Loaded="InstanceEditorPanel_OnLoaded"
                                    LostKeyboardFocus="InstanceEditorPanel_OnLostKeyboardFocus">
                            <TextBox x:Name="InstanceNameEditor"
                                     Margin="0,0,0,4"
                                     MinWidth="220"
                                     Text="{Binding EditableName, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="InstanceEditor_OnKeyDown" />
                            <TextBox x:Name="DatabaseNameEditor"
                                     MinWidth="220"
                                     Text="{Binding EditableDatabaseName, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="InstanceEditor_OnKeyDown" />
                        </StackPanel>
                    </Grid>
                </HierarchicalDataTemplate>

                <DataTemplate DataType="{x:Type vm:FilterNodeViewModel}">
                    <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
            </TreeView.Resources>
        </TreeView>
    </DockPanel>
</Window>