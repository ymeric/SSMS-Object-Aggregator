<UserControl x:Class="SSMS.ObjectAggregator.Views.SmartObjectFilterWindow"
        x:Name="RootControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SSMS.ObjectAggregator.ViewModels"
        xmlns:conv="clr-namespace:SSMS.ObjectAggregator.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />

        <Style x:Key="ChildTreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="ContextMenu" Value="{x:Null}" />
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type vm:GroupViewModel}" ItemsSource="{Binding ObjectNodes}">
            <Grid>
                <TextBlock Text="{Binding Name}" Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}" />
                <TextBox Text="{Binding EditableName, UpdateSourceTrigger=PropertyChanged}"
                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                         MinWidth="200"
                         Loaded="GroupNameEditor_OnLoaded"
                         LostFocus="GroupNameEditor_OnLostFocus"
                         KeyDown="GroupNameEditor_OnKeyDown" />
            </Grid>
            <HierarchicalDataTemplate.ItemContainerStyle>
                <Style TargetType="TreeViewItem" BasedOn="{StaticResource ChildTreeViewItemStyle}" />
            </HierarchicalDataTemplate.ItemContainerStyle>
        </HierarchicalDataTemplate>

        <HierarchicalDataTemplate DataType="{x:Type vm:InstanceDatabaseNodeViewModel}" ItemsSource="{Binding FilteredTypeGroups}">
            <StackPanel>
                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                <DockPanel Margin="0,3,0,0">
                    <TextBlock DockPanel.Dock="Left"
                               FontFamily="Segoe MDL2 Assets" Text="&#xE71E;"
                               FontSize="11" Foreground="Gray"
                               VerticalAlignment="Center" Margin="0,0,3,0" />
                    <Grid>
                        <TextBox Text="{Binding QuickSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="2,1" FontSize="11" MinWidth="110"
                                 KeyDown="QuickSearchBox_OnKeyDown" />
                        <TextBlock Text="filter objects…" IsHitTestVisible="False"
                                   FontSize="11" FontStyle="Italic" Foreground="Gray"
                                   Margin="4,0,0,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding QuickSearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </DockPanel>
            </StackPanel>
        </HierarchicalDataTemplate>

        <HierarchicalDataTemplate DataType="{x:Type vm:ObjectTypeGroupViewModel}" ItemsSource="{Binding FilteredChildren}">
            <TextBlock Text="{Binding DisplayName}" />
        </HierarchicalDataTemplate>

        <DataTemplate DataType="{x:Type vm:SqlObjectNodeViewModel}">
            <TextBlock Text="{Binding DisplayName}" Margin="4,2">
                <TextBlock.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Locate"
                                  Command="{Binding DataContext.LocateObjectCommand, Source={x:Reference RootControl}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </ContextMenu>
                </TextBlock.ContextMenu>
            </TextBlock>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PlaceholderNodeViewModel}">
            <TextBlock Text="{Binding Message}" FontStyle="Italic" Foreground="Gray" Margin="4,2" />
        </DataTemplate>

        <Style x:Key="GroupTreeViewItemStyle" TargetType="TreeViewItem">
            <EventSetter Event="Expanded" Handler="GroupTreeViewItem_OnExpanded" />
            <EventSetter Event="MouseDoubleClick" Handler="GroupTreeViewItem_OnMouseDoubleClick" />
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <MenuItem Header="Rename"
                                  Command="{Binding DataContext.RenameGroupContextCommand, Source={x:Reference RootControl}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Add Instance"
                                  Command="{Binding DataContext.AddInstanceContextCommand, Source={x:Reference RootControl}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Edit"
                                  Command="{Binding DataContext.EditGroupContextCommand, Source={x:Reference RootControl}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Delete"
                                  Command="{Binding DataContext.DeleteGroupContextCommand, Source={x:Reference RootControl}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </ContextMenu>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Groups">
                <MenuItem Header="_Reload Group" Command="{Binding ReloadGroupCommand}" />
                <MenuItem Header="_Add Group" Command="{Binding AddGroupCommand}" />
                <MenuItem Header="_Edit Group" Command="{Binding EditGroupCommand}" />
                <MenuItem Header="_Delete Group" Command="{Binding DeleteGroupCommand}" />
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top" IsLocked="True">
        <ToolBar>
            <Button Command="{Binding ReloadGroupCommand}" ToolTip="Reload Group">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72C;" FontSize="16" />
            </Button>
            <Button Command="{Binding AddGroupCommand}" ToolTip="Add Group" Margin="4,0,0,0">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="16" />
            </Button>
            <Button Command="{Binding EditGroupCommand}" ToolTip="Edit Group" Margin="4,0,0,0">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70F;" FontSize="16" />
            </Button>
            <Button Command="{Binding DeleteGroupCommand}" ToolTip="Delete Group" Margin="4,0,0,0">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="16" />
            </Button>
        </ToolBar>
        </ToolBarTray>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="{Binding SelectedGroup.StatusMessage}" />
        </StatusBar>

        <TreeView x:Name="GroupsTree"
                  Margin="8"
                  ItemsSource="{Binding Groups}"
                  SelectedItemChanged="GroupsTree_OnSelectedItemChanged"
                  PreviewKeyDown="GroupsTree_OnPreviewKeyDown"
                  ItemContainerStyle="{StaticResource GroupTreeViewItemStyle}" />
    </DockPanel>
</UserControl>